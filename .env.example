# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
AUTO_PORT_FALLBACK=true
CORS_ORIGIN=*

# ── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── NVIDIA AI (free at build.nvidia.com) ────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Blockchain ──────────────────────────────────────────────────
BLOCKCHAIN_MODE=demo
# Optional: Hyperledger Fabric bridge
FABRIC_SUBMIT_URL=http://localhost:4000/submit-integrity
FABRIC_SUBMIT_API_KEY=replace-with-shared-secret
FABRIC_BRIDGE_REQUIRED=false

# ── Security ────────────────────────────────────────────────────
IMPOSSIBLE_TRAVEL_THRESHOLD_KMPH=900

# ── Frontend service redirects ──────────────────────────────────
VITE_TAX_SERVICE_URL=http://localhost:3001
VITE_PASSPORT_SERVICE_URL=http://localhost:3012
VITE_PARIVAHAN_SERVICE_URL=http://localhost:3013

# ── Vite HMR ────────────────────────────────────────────────────
VITE_HMR_PORT=24678
