# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TrustGov backend configuration
PORT=3000
NODE_ENV="development"
AUTO_PORT_FALLBACK="true"

# MongoDB Atlas
MONGO_URI="mongodb+srv://<username>:<password>@<cluster-url>/trustgov?retryWrites=true&w=majority"
MONGO_DB_NAME="trustgov"
USERS_COLLECTION="users"
TOKEN_RECORDS_COLLECTION="token_records"
SERVICE_REQUESTS_COLLECTION="service_requests"
ACTIVITY_COLLECTION="activity_logs"

# Security
JWT_SECRET="replace-with-a-strong-secret"
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"
DEMO_OTP="123456"
CORS_ORIGIN="*"
FORCE_HTTPS="false"


# Blockchain mode
# - demo: always allows fallback id generation
# - amb-verify: requires AWS network verification (fails if AMB_STRICT=true)
# - fabric-bridge: uses FABRIC_SUBMIT_URL endpoint for txId
BLOCKCHAIN_MODE="demo"

# Hyperledger Fabric submit bridge (recommended for Step 3 real on-chain writes)
# This should point to an API running on the machine that can access your Fabric network.
FABRIC_SUBMIT_URL="http://<friend-laptop-ip>:4000/submit-integrity"
FABRIC_SUBMIT_API_KEY="replace-with-shared-secret"
FABRIC_BRIDGE_REQUIRED="false"

# Frontend redirects for linked service portals
VITE_TAX_SERVICE_URL="http://localhost:3001"

# Firebase Phone Auth (frontend)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_ALLOW_DEMO_PHONE_FALLBACK="true"

# Firebase Admin (backend token verification)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
